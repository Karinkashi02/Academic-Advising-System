<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
   http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
   version="3.1">
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <servlet>
        <servlet-name>AdvisorReportServlet</servlet-name>
        <servlet-class>com.advising.controller.AdvisorReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdvisorReportServlet</servlet-name>
        <url-pattern>/api/advisor/report</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>StudentPerformanceReportServlet</servlet-name>
        <servlet-class>com.advising.controller.StudentPerformanceReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentPerformanceReportServlet</servlet-name>
        <url-pattern>/api/advisor/performance</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>SessionReportServlet</servlet-name>
        <servlet-class>com.advising.controller.SessionReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SessionReportServlet</servlet-name>
        <url-pattern>/api/advisor/sessions-report</url-pattern>
    </servlet-mapping>
</web-app>
